-    }
-    size_t retSize = std::fread(buffer.get(), 1, fileSize, fp);
-    if (retSize != fileSize) {
-        HILOG_ERROR("ReadFileToBuffer:read file result size = %{public}zu, size = %{public}zu.", retSize, fileSize);
-        fclose(fp);
-        return nullptr;
-    }
-    fclose(fp);
-    return buffer;
